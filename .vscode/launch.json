{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI: allegro (uv + .env.cli)",
      "type": "debugpy",
      "request": "launch",
      "module": "uv",
      "args": [
        "run",
        "cli/allegro.py2",
        "fetch",
        "--dry-run"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.cli",
      "justMyCode": true
    },
    {
      "name": "Debug FastAPI: uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:create_production_app",
        "--factory",
        "--app-dir",
        "src",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Python Debugger: Python File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}"
    }
  ]
}
